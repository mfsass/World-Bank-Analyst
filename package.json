{
  "private": true,
  "scripts": {
    "app": "node scripts/dev.js",
    "app:prod": "node scripts/dev.js --prod",
    "frontend": "cd frontend && npm run dev",
    "backend": "cd api && python app.py",
    "deploy": "node scripts/deploy.js",
    "deploy:skip-build": "node scripts/deploy.js --skip-build",
    "eval": "python -m pipeline.evaluation",
    "test:api": "cd api && python -m pytest tests/ -v",
    "test:pipeline": "cd pipeline && python -m pytest tests/ -v",
    "test:frontend": "cd frontend && npm test"
  }
}
